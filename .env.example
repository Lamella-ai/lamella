# Lamella - AI-powered bookkeeping software that provides context-aware financial intelligence
# https://lamella.ai
#
# Sample environment configuration. Copy to `.env` and edit to taste.
# Settings are read by pydantic-settings at startup; defaults live in
# src/lamella/core/config.py.

# ---------------------------------------------------------------------
# Storage paths
# ---------------------------------------------------------------------

# Where SQLite + uploads + auto-generated session secret live. The
# default `/data` is the in-container path; for non-Docker dev runs
# point this somewhere writable on the host.
LAMELLA_DATA_DIR=/data

# Beancount ledger root. Must contain `main.bean`.
LAMELLA_LEDGER_DIR=/ledger


# ---------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------

# Bind address. Default 127.0.0.1 (loopback only) for non-Docker runs.
# The Docker entrypoint sets HOST=0.0.0.0 explicitly because the
# container's network namespace is isolated; the operator's port
# mapping is the real exposure boundary. Outside Docker, change this
# to 0.0.0.0 only when you have an authenticating reverse proxy or a
# private LAN that you trust to be the only ingress.
HOST=127.0.0.1
PORT=8080


# ---------------------------------------------------------------------
# Authentication (ADR-0050) — OPTIONAL but strongly recommended
# ---------------------------------------------------------------------
#
# Auth is OFF by default. Setting AUTH_USERNAME plus exactly one of
# AUTH_PASSWORD / AUTH_PASSWORD_HASH on the FIRST run bootstraps a
# single user into the SQLite users table. Subsequent runs ignore
# these variables — you change the password through /account/password
# in the app once you're signed in.
#
# Always set this when binding to anything other than 127.0.0.1.

# AUTH_USERNAME=admin

# Plaintext bootstrap (convenience):
# AUTH_PASSWORD=change-me-on-first-login

# OR pre-hashed bootstrap (recommended for shared compose files):
#   $ python3 -c "from argon2 import PasswordHasher; print(PasswordHasher().hash('your-password'))"
# AUTH_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=2$...

# Cookie-signing secret. If unset, an auto-generated value is
# persisted to <data_dir>/.session-secret on first start. Set
# this explicitly when you want to share sessions across replicas
# (multi-instance SaaS) or when the data directory is ephemeral.
# AUTH_SESSION_SECRET=replace-with-a-random-64+-byte-string

# Session lifetime in days (rolled forward on every authenticated request).
AUTH_SESSION_DAYS=30

# Lockout policy — depth-in-defense; the proxy layer is your real
# rate limiter.
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_WINDOW_MINUTES=15
AUTH_LOCKOUT_DURATION_MINUTES=15


# ---------------------------------------------------------------------
# AI / OpenRouter (Phase 3)
# ---------------------------------------------------------------------

# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# AI_MAX_MONTHLY_SPEND_USD=25


# ---------------------------------------------------------------------
# Paperless integration
# ---------------------------------------------------------------------

# PAPERLESS_URL=https://paperless.your-domain
# PAPERLESS_API_TOKEN=...

# Cloudflare Zero Trust service token (only when Paperless is gated):
# PAPERLESS_CF_ACCESS_CLIENT_ID=...
# PAPERLESS_CF_ACCESS_CLIENT_SECRET=...


# ---------------------------------------------------------------------
# SimpleFIN (Phase 4 — bank-feed takeover)
# ---------------------------------------------------------------------

# SIMPLEFIN_ACCESS_URL=https://...
# SIMPLEFIN_MODE=disabled       # disabled | shadow | active
# SIMPLEFIN_FETCH_INTERVAL_HOURS=6
# SIMPLEFIN_LOOKBACK_DAYS=14


# ---------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------

# NTFY_TOPIC=your-private-topic
# PUSHOVER_USER_KEY=...
# PUSHOVER_API_TOKEN=...


# ---------------------------------------------------------------------
# Logging + timezone
# ---------------------------------------------------------------------

LOG_LEVEL=INFO
APP_TZ=UTC
