__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/
*.db
*.db-journal
*.db-wal
*.db-shm
data/
data.*/
ledger/
# Any ledger-* / ledger.* variant: ad-hoc backup copies produced by
# manual edits or recovery tools. ledger.journey-bak/, ledger.bak/,
# ledger-2026-04-24/, etc. — all the user's real data, never ours to
# commit.
ledger-*/
ledger.*/
# Exception: the public demo ledger is generated by
# scripts/generate_demo.py and is committed so anyone cloning the
# repo can run it (and so a CI bean-check guards against drift from
# the chart-of-accounts spec). All names in there are placeholders
# per ADR-0017 — no real PII, no real merchants.
!ledger.demo/
!ledger.demo/**
# Manual tar/zip ledger snapshots also land in repo root sometimes.
ledger-*.tar
ledger-*.tar.gz
ledger-*.zip
ledger.*.tar
ledger.*.tar.gz
ledger.*.zip
# Per-file backup suffixes the server writes before risky edits
# (dedupe, orphan-override cleanup, scaffold rollback, etc.). These
# land INSIDE ledger/ which is already ignored, but list the suffixes
# explicitly so a misplaced copy in the repo root can't slip through.
*.bak
*.predup.bak
*.preclean.bak
*.pre-property-cleanup.bak
*.journey-bak
# SQLite sidecar files + any stray .sqlite we might produce outside data/.
*.sqlite
*.sqlite-shm
*.sqlite-wal
.DS_Store
.idea/
.vscode/
.claude/scheduled_tasks.lock
# Anything ending in `.local` or containing `.local.` is treated as a
# local-only artifact (denylists, dev settings, environment overrides).
# Never tracked, never sanitized — they're not part of the public surface.
*.local
*.local.*

# NOTE: docs/internal/, audits/, swarm-run-*.md, importer_bundle/ USED
# to live here. They moved to .releaseignore so the private repo tracks
# them (useful history) but the public release strips them. The rule:
# anything .releaseignore-stripped is allowed to contain PII because it
# never ships publicly. See release.sh.

# Claude Design Fetch handoff bundles (extracted from claude.ai/design).
# 21MB+ of HTML/CSS, marginal value to track even privately.
.design-fetch/

# /inventory diff working file — only the canonical docs/inventory.md is
# tracked. The .prev.md exists so the next run can compute a diff.
docs/inventory.prev.md

# /coverage-trend raw coverage export — only the dated .md report and
# trend.csv are tracked; the JSON regenerates on every run.
audits/coverage/coverage.json
.coverage
.coverage.*

# Synology metadata
@eaDir/
.SynologyWorkingDirectory/
*.SynologyArchive

# OS metadata
Thumbs.db
desktop.ini

# .claude/ houses two kinds of files:
#   1. Project-specific workflow assets we author (commands/*.md,
#      settings.local.json) - tracked
#   2. claude-flow installed tooling (agents/, helpers/, skills/,
#      statusline.*, etc.) - ignored
# This pattern allowlists (1) and ignores (2). When adding new tracked
# content, add an explicit `!` rule below.
.claude/*
!.claude/commands/
.claude/commands/*/
!.claude/commands/*.md
.claude/commands/claude-flow-*.md

# Claude-flow runtime state directories.
.claude-flow/
.swarm/

# Ruflo / claude-flow MCP memory backing files (sql.js + HNSW). Runtime
# state, not source.
agentdb.rvf
agentdb.rvf.lock
agentdb.rvf-journal
